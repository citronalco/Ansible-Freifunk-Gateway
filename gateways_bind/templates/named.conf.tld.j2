// {{ ansible_managed }}

{% for domain in domains %}
zone "{{domain}}" IN {
	type slave;
        file "/etc/bind/slave/db.{{domain}}";
	masters {
{% for master in bind.ffnet_zone_masters %}
		{{master}};
{% endfor %}
	};
};
zone "{{ [ bind.server_subdomain, domain ] | select('defined') | join('.') }}." IN {
	type slave;
        file "/etc/bind/slave/db.{{ [ bind.server_subdomain, domain ] | select('defined') | join('.') }}";
	masters {
{% for master in bind.ffnet_zone_masters %}
		{{master}};
{% endfor %}
	};
};
zone "services.{{domain}}." IN {
	type slave;
        file "/etc/bind/slave/db.services.{{domain}}";
	masters {
{% for master in bind.ffnet_zone_masters %}
		{{master}};
{% endfor %}
	};
};
zone "knoten.{{domain}}." IN {
	type slave;
        file "/etc/bind/slave/db.knoten.{{domain}}";
	masters {
{% for master in bind.ffnet_zone_masters %}
		{{master}};
{% endfor %}
	};
};
{% endfor %}
